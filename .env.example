# Copy to .env.local and fill in.

# Postgres. Local Docker, Supabase, Neon, RDS, and other normal Postgres
# providers work. If Vercel provisions it, pull with `vercel env pull`.
DATABASE_URL=postgres://idea_bench:idea_bench@localhost:5432/idea_bench

# Operator password for the single-operator login flow.
OPERATOR_PASSWORD=changeme

# HMAC secret for signing operator + participant cookies.
# Generate with:   openssl rand -hex 32
# Rotating this value invalidates every outstanding cookie.
AUTH_SECRET=replace_with_32_plus_chars_of_randomness

# OpenRouter. Server-only; never ship to the client.
# Get one at https://openrouter.ai/keys — $5 of credit works for many campaigns.
OPENROUTER_API_KEY=sk-or-...

# Optional: advertised as the Referer to OpenRouter. Used for their analytics.
# OPENROUTER_APP_URL=https://idea-bench.your-domain.com

# Comma-separated identities (emails or GitHub logins, matched case-insensitively
# against the operator session's `identity` field) allowed to trigger
# AI-spending endpoints (`generate`, `simulated-runs/run`, `personas/test`).
# Should be a subset of OPERATOR_EMAILS / OPERATOR_GITHUB_LOGINS — the login
# allowlist decides who can sign in, this one decides who can spend.
# Password sessions have identity `operator` (shared literal); do NOT add that
# word here. Leave empty to disable AI entirely (fail-closed, returns 503).
AI_ALLOWED_IDENTITIES=

# GitHub OAuth (optional alternate sign-in).
# Register an OAuth App at https://github.com/settings/developers with
# callback URL `${origin}/api/auth/github-callback`, then paste credentials here.
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
# Comma-separated GitHub logins OR verified emails. A sign-in is allowed if
# either the GitHub username OR any verified email on the account matches.
OPERATOR_GITHUB_LOGINS=

# Email magic link (optional alternate sign-in).
# Comma-separated allowlist of email addresses permitted to request a link.
OPERATOR_EMAILS=
# Resend API key — get one at https://resend.com. Required for magic links.
RESEND_API_KEY=
# Optional: `From:` address for magic-link emails. Defaults to
# `onboarding@resend.dev` (Resend's sandbox, delivers only to your verified
# account email). Set a real address once your sending domain is verified.
# RESEND_SENDER_ADDRESS=auth@your-domain.com
