{
  "buildCommand": "npm run deploy:check && npm run build",
  "rewrites": [
    { "source": "/login", "destination": "/login.html" },
    { "source": "/api/simulated-runs", "destination": "/api/simulated-runs/__root" },
    { "source": "/api/personas", "destination": "/api/personas/__root" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "crons": [
    { "path": "/api/cron/purge-deleted", "schedule": "0 3 * * *" }
  ]
}
