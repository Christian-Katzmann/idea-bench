# Copy to .env.local and fill in.

# Postgres (Neon). Provisioned automatically by the Vercel Marketplace
# integration; pull to your local env with `vercel env pull`.
DATABASE_URL=postgres://user:pass@host/dbname?sslmode=require

# Operator password for the single-operator login flow.
OPERATOR_PASSWORD=changeme

# HMAC secret for signing operator + participant cookies.
# Generate with:   openssl rand -hex 32
# Rotating this value invalidates every outstanding cookie.
AUTH_SECRET=replace_with_32_plus_chars_of_randomness

# Phase 2 — server-only. Never ship to the client.
# OPENROUTER_API_KEY=sk-or-...
